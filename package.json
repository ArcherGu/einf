{
  "name": "einf",
  "version": "0.0.0",
  "packageManager": "pnpm@11.13.1",
  "description": "A simple electron main process framework",
  "author": "ArcherGu",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/ArcherGu/einf"
  },
  "keywords": [
    "electron",
    "framework",
    "decorator",
    "metadata"
  ],
  "main": "dist/index.cjs",
  "types": "dist/index.d.cts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=14"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm build && vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "electron": ">=16.0.0"
  },
  "dependencies": {
    "colorette": "^2.0.20",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@lightwing/eslint-config": "1.0.156",
    "@types/node": "25.9.5",
    "@typescript/native": "npm:typescript@7.0.2",
    "baseline-browser-mapping": "^2.10.33",
    "electron": "43.1.1",
    "eslint": "10.4.1",
    "execa": "10.0.0",
    "lint-staged": "17.0.8",
    "semantic-release": "25.0.8",
    "simple-git-hooks": "2.13.1",
    "tsdown": "^0.22.1",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "vite": "8.1.5",
    "vite-plugin-doubleshot": "0.0.25",
    "vitest": "4.1.10"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,md,json,yml}": [
      "eslint --fix"
    ]
  }
}
