{
  "name": "einf",
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.0",
  "description": "A simple electron main process framework",
  "author": "ArcherGu",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/ArcherGu/einf.git"
  },
  "keywords": [
    "electron",
    "framework",
    "decorator",
    "metadata"
  ],
  "main": "dist/index.cjs",
  "types": "dist/index.d.cts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=14"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm build && vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "electron": ">=16.0.0"
  },
  "dependencies": {
    "colorette": "^2.0.20",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@lightwing/eslint-config": "1.0.154",
    "@types/node": "25.6.0",
    "baseline-browser-mapping": "^2.10.10",
    "electron": "41.2.2",
    "eslint": "10.2.1",
    "execa": "9.6.1",
    "lint-staged": "16.4.0",
    "simple-git-hooks": "2.13.1",
    "tsdown": "^0.21.4",
    "typescript": "6.0.3",
    "vite": "8.0.9",
    "vite-plugin-doubleshot": "0.0.22",
    "vitest": "4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "electron",
      "esbuild",
      "simple-git-hooks"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,md,json,yml}": [
      "eslint --fix"
    ]
  }
}
